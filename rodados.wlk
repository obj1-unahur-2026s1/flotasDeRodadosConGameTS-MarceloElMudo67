
class Rodado {
    var capacidad = 0
    var velocidadMax = 0
    var color = rojo
    var peso = 0

    method cambiarCapacidad(unaCapacidad) {
        capacidad = unaCapacidad
      
    }
    method capacidad() = capacidad
    method cambiarVelocidad(unaVelocidad) {
        velocidadMax = unaVelocidad
      
    }
    method velocidadMax() = velocidadMax
    method cambiarColor(unColor) {
        color = unColor
      
    }
    method color() = color
  
}